-- Test 19: bm25_decrement_idf_stats adjusts counts correctly
---------------------------------------------------------------------------
-- Seed a term into the IDF stats table
INSERT INTO hybrid_test_docs_content_chunks_idf_stats
    (term, doc_freq, total_docs, idf_weight)
VALUES ('testterm', 5, 10, 1.0);
-- Decrement by 1
 bm25_decrement_idf_stats 
--------------------------
 
(1 row)

-- Verify the count was reduced
   term   | doc_freq 
----------+----------
 testterm |         4
(1 row)

-- Clean up the test row
DELETE FROM hybrid_test_docs_content_chunks_idf_stats WHERE term = 'testterm';
---------------------------------------------------------------------------
-- Test 20: disable_vectorization with drop_chunk_table also drops _idf_stats
---------------------------------------------------------------------------
-- Create a second vectorized column to test cleanup
CREATE TABLE hybrid_cleanup_test (
    id      BIGSERIAL PRIMARY KEY,
    body    TEXT
);
SELECT pgedge_vectorizer.enable_vectorization(
    'hybrid_cleanup_test'::regclass,
    'body',
    'token_based',
    100,
    10,
    1536
);
NOTICE:  Using primary key column: id (bigint)
NOTICE:  column "sparse_embedding" of relation "hybrid_cleanup_test_body_chunks" already exists, skipping
NOTICE:  Vectorization enabled: hybrid_cleanup_test -> hybrid_cleanup_test_body_chunks
NOTICE:  Strategy: token_based, chunk_size: 100, overlap: 10
NOTICE:  Processing existing rows...
NOTICE:  Processed 0 existing rows
 enable_vectorization 
----------------------
 
(1 row)

-- Verify _idf_stats table exists before disable
                 tablename                 
-------------------------------------------
 hybrid_cleanup_test_body_chunks_idf_stats
(1 row)

-- Disable with drop
SELECT pgedge_vectorizer.disable_vectorization(
    'hybrid_cleanup_test'::regclass, 'body', true
);
NOTICE:  Vectorization disabled and chunk table dropped: hybrid_cleanup_test_body_chunks
 disable_vectorization 
-----------------------
 
(1 row)

-- Verify _idf_stats table was also dropped
 idf_stats_exists 
------------------
                0
(1 row)

DROP TABLE hybrid_cleanup_test;
---------------------------------------------------------------------------
-- Test 21: multi-column disambiguation error in hybrid_search
---------------------------------------------------------------------------
-- Create a table with two vectorized columns
CREATE TABLE hybrid_multi_test (
    id    BIGSERIAL PRIMARY KEY,
    title TEXT,
    body  TEXT
);
SELECT pgedge_vectorizer.enable_vectorization(
    'hybrid_multi_test'::regclass,
    'title',
    'token_based', 100, 10, 1536
);
NOTICE:  Using primary key column: id (bigint)
NOTICE:  column "sparse_embedding" of relation "hybrid_multi_test_title_chunks" already exists, skipping
NOTICE:  Vectorization enabled: hybrid_multi_test -> hybrid_multi_test_title_chunks
NOTICE:  Strategy: token_based, chunk_size: 100, overlap: 10
NOTICE:  Processing existing rows...
NOTICE:  Processed 0 existing rows
 enable_vectorization 
----------------------
 
(1 row)

SELECT pgedge_vectorizer.enable_vectorization(
    'hybrid_multi_test'::regclass,
    'body',
    'token_based', 100, 10, 1536
);
NOTICE:  Using primary key column: id (bigint)
NOTICE:  column "sparse_embedding" of relation "hybrid_multi_test_body_chunks" already exists, skipping
NOTICE:  Vectorization enabled: hybrid_multi_test -> hybrid_multi_test_body_chunks
NOTICE:  Strategy: token_based, chunk_size: 100, overlap: 10
NOTICE:  Processing existing rows...
NOTICE:  Processed 0 existing rows
 enable_vectorization 
----------------------
 
(1 row)

-- hybrid_search without specifying column should raise
SET pgedge_vectorizer.enable_hybrid = true;
DO $$
BEGIN
    PERFORM pgedge_vectorizer.hybrid_search(
        'hybrid_multi_test'::regclass, 'test query', 5
    );
    RAISE EXCEPTION 'Expected exception was not raised';
EXCEPTION
    WHEN OTHERS THEN
        IF sqlerrm LIKE '%multiple vectorized columns%' THEN
            RAISE NOTICE 'Got expected exception: %', sqlerrm;
        ELSE
            RAISE;
        END IF;
END;
$$;
NOTICE:  Got expected exception: Table hybrid_multi_test has multiple vectorized columns. Pass p_source_column to disambiguate.
RESET pgedge_vectorizer.enable_hybrid;
-- Clean up
SELECT pgedge_vectorizer.disable_vectorization(
    'hybrid_multi_test'::regclass, NULL, true
);
NOTICE:  Dropped trigger: hybrid_multi_test_title_vectorization_trigger
NOTICE:  Dropped trigger: hybrid_multi_test_body_vectorization_trigger
NOTICE:  Vectorization disabled and chunk table dropped: hybrid_multi_test_title_chunks
NOTICE:  Vectorization disabled and chunk table dropped: hybrid_multi_test_body_chunks
 disable_vectorization 
-----------------------
 
(1 row)

DROP TABLE hybrid_multi_test;
